{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --external @mapbox/node-pre-gyp",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test --coverage --bail",
    "db:migrate": "bunx prisma migrate dev --config prisma/prisma.config.ts",
    "db:generate": "bunx prisma generate --config prisma/prisma.config.ts",
    "db:push": "bunx prisma db push --config prisma/prisma.config.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.7.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "resend": "^6.10.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.1",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/validator": "^13.15.10",
    "bun-types": "^1.3.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  }
}
