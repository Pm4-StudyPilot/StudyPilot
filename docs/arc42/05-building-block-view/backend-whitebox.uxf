    <panel_attributes>5. Middleware + Cross Cutting
--
middleware/*
- authenticate
- rateLimiter
config/passport.ts
lib/logger.ts</panel_attributes>
    <additional_attributes/>
  </element>
  <element>
    <id>UMLClass</id>
    <coordinates>
