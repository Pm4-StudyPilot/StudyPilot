    <panel_attributes>4. Service Layer (Business Logic)
--
services/*
- AuthService
- UserService
- CourseService
- TaskService
- DocumentService
- EmailService
- MinioService / StorageService</panel_attributes>
    <additional_attributes/>
  </element>
  <element>
    <id>UMLClass</id>
    <coordinates>
      <x>450</x>
